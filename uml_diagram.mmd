graph LR
    %% Actors
    ((Student)) -->|1. Enters tracking number| UC1
    ((Student)) -->|2. Views live tracking| UC2
    ((Student)) -->|3. Saves to notifications| UC3
    
    ((Registrar)) -->|4. Enters tracking for shipment| UC4
    ((System)) -->|5. Fetches from LBC API| UC5
    ((System)) -->|6. Returns tracking data| UC2
    
    subgraph System_Boundary [Document Request & Tracking System]
        UC1([Enter Tracking Number])
        UC2([View Live Tracking])
        UC3([Save to Notifications])
        UC4([Enter Tracking for Shipment])
        UC5[[Fetch LBC API]]
        
        UC1 -->|includes| UC2
        UC3 -.->|<<include>>| UC2
        UC4 -->|triggers| UC5
    end
    
    style System_Boundary fill:#f8f9fa,stroke:#333,stroke-width:2px
    style UC1 fill:#e3f2fd,stroke:#1976d2,stroke-width:2px
    style UC2 fill:#e8f5e9,stroke:#388e3c,stroke-width:2px
    style UC3 fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    style UC4 fill:#fce4ec,stroke:#c2185b,stroke-width:2px
    style UC5 fill:#f5f5f5,stroke:#616161,stroke-width:1px,stroke-dasharray:5 5
```
