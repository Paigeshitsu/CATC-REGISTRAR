@startuml Make Payment Sequence
skinparam dpi 300
skinparam fontSize 14
skinparam entityFontSize 14
skinparam classFontSize 14
skinparam noteFontSize 14
skinparam actorFontSize 14
skinparam rectangleFontSize 14
skinparam participantFontSize 14
skinparam collectionsFontSize 14
!theme plain

actor Student
participant ":StudentDashboardView" as Dashboard
participant ":CashierDashboardView" as Cashier
participant ":DocumentRequest" as Request
participant ":CollectionLog" as Collection
participant ":SystemCounter" as Counter
actor Cashier

alt Online Payment
    Student -> Dashboard: Make Online Payment
    Dashboard -> Request: Update status to PENDING_CASHIER_APPROVAL
else Cash Payment
    Student -> Cashier: Present Request ID
    Cashier -> Request: Confirm Payment Amount
    Cashier -> Counter: Get Next Receipt Number
    Counter --> Cashier: OR Number
    Cashier -> Collection: Create CollectionLog
    Cashier -> Request: Update status to PAID
end
Request --> Student: Show Payment Confirmation
Cashier --> Student: Generate Official Receipt

@enduml