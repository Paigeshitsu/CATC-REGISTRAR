@startuml Manage System Configuration
!theme plain
autonumber

actor Admin
participant "Django Admin / Settings UI" as UI
participant "Admin Service" as AdminService
participant "User / Group" as UserGroup
participant "DocumentType" as DocumentType
participant "Profile" as Profile
participant "AuditLog" as Audit

Admin -> UI : Manage users, roles, document prices, signatures

alt Manage user roles
  UI -> AdminService : Create or update staff user
  AdminService -> UserGroup : Assign groups and permissions
  AdminService -> Audit : Record user change
else Manage document catalog
  UI -> AdminService : Update document type or price
  AdminService -> DocumentType : Save catalog changes
  AdminService -> Audit : Record pricing action
else Manage signature settings
  UI -> AdminService : Update printed name / signature
  AdminService -> Profile : Save signature settings
  AdminService -> Audit : Record profile action
end

AdminService --> UI : Show updated configuration

@enduml
